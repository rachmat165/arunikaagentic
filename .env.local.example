# ============================================================
# ARUNIKA AGENTIC AI — Environment Variables
# PT. Arunika Teknologi Global | corsec@arunika2045.com
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/arunika_agentic

# ── APPLICATION ───────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_NAME=Arunika Agentic AI

# ── FASE 6: SECURITY ──────────────────────────────────────────
# Encryption key for API key storage (AES-256-GCM)
# Generate with: openssl rand -hex 32
API_KEY_ENCRYPTION_KEY=your_64_char_hex_key_here

# Admin secret for CEO-only API routes (/api/approvals/keys)
# Generate with: openssl rand -hex 16
ADMIN_SECRET_KEY=your_admin_secret_here

# ── AI API KEYS ───────────────────────────────────────────────
# Set these ONLY for initial setup, then run: npm run setup:encrypt-keys
# After setup, keys are encrypted in DB — remove from .env.local
CLAUDE_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-proj-xxxxx
GEMINI_API_KEY=xxxxx

# ── NOTIFICATIONS (Optional) ──────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx
SENDGRID_API_KEY=SG.xxxxx
NOTIFICATION_EMAIL_FROM=corsec@arunika2045.com

# ── GCP (Existing) ────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
