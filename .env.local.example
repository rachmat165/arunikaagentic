# Database Configuration
# PostgreSQL connection string with the following format:
# postgres://username:password@hostname:port/database_name
DATABASE_URL=postgres://user:password@localhost:5432/arunika_agentic

# Node Environment
NODE_ENV=development

# API Server
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: Individual database configuration (if not using DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=arunika_agentic
# DB_USER=postgres
# DB_PASSWORD=your_password
